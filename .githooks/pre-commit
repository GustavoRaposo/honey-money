#!/bin/sh
# Validações obrigatórias antes de cada commit.
# Instalado automaticamente via `npm run prepare` dentro de apps/api/.

set -e

cd apps/api

echo "→ typecheck..."
npm run typecheck

echo "→ lint..."
npm run lint

echo "→ testes..."
npm test

echo "→ postman collection..."
npm run postman:generate && git add apps/api/honey-money.postman_collection.json
