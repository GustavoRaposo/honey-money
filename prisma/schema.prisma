generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdTasks     Task[] @relation("TaskCreatedBy")
  assignedTasks    Task[] @relation("TaskAssignedTo")
  lastUpdatedTasks Task[] @relation("TaskLastUpdatedBy")

  @@map("users")
}

model TaskStatus {
  id    Int    @id @default(autoincrement())
  code  Int    @unique
  name  String

  tasks Task[]

  @@map("task_statuses")
}

model Task {
  id              Int      @id @default(autoincrement())
  name            String
  description     String?
  priority        Int      @default(1)
  statusCode      Int      @default(0) @map("status_code")
  createdById     Int       @map("created_by_id")
  assignedToId    Int?      @map("assigned_to_id")
  lastUpdatedById Int?      @map("last_updated_by_id")
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  isRecurrent        Boolean   @default(false) @map("is_recurrent")
  parentTaskId       Int?      @map("parent_task_id")
  recurrenceType     String?   @map("recurrence_type")
  recurrenceDays     String?   @map("recurrence_days")
  recurrenceTime     String?   @map("recurrence_time")
  recurrenceDuration String?   @map("recurrence_duration")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  status        TaskStatus @relation(fields: [statusCode], references: [code])
  createdBy     User       @relation("TaskCreatedBy", fields: [createdById], references: [id])
  assignedTo    User?      @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  lastUpdatedBy User?      @relation("TaskLastUpdatedBy", fields: [lastUpdatedById], references: [id])
  parent        Task?      @relation("TaskOccurrences", fields: [parentTaskId], references: [id])
  children      Task[]     @relation("TaskOccurrences")

  @@map("tasks")
}
